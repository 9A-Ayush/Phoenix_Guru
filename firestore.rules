rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Classes ────────────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      allow update: if request.auth != null
                    && (
                      resource.data.teacherId == request.auth.uid
                      ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
                    );
      allow delete: if request.auth != null
                    && resource.data.teacherId == request.auth.uid;

      // ── Materials (subcollection under classes) ───────────────────────────
      match /materials/{materialId} {
        // Any authenticated user can read materials
        allow read: if request.auth != null;
        // Only the class teacher can create/update/delete materials
        allow create: if request.auth != null
                      && get(/databases/$(database)/documents/classes/$(classId))
                         .data.teacherId == request.auth.uid;
        allow update: if request.auth != null
                      && get(/databases/$(database)/documents/classes/$(classId))
                         .data.teacherId == request.auth.uid;
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/classes/$(classId))
                         .data.teacherId == request.auth.uid;
      }
    }

    // ── Tests ──────────────────────────────────────────────────────────────
    match /tests/{testId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // ── Attempts ───────────────────────────────────────────────────────────
    match /attempts/{attemptId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      // Student can update/delete their own attempt.
      // Teacher can delete any attempt (needed when deleting a test + its attempts).
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && (
                      resource.data.userId == request.auth.uid
                      ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
                    );
    }

    // ── Live Sessions ───────────────────────────────────────────────────────
    // Any authenticated user can read sessions (to join by PIN).
    // Only the host (teacher) can create/update/delete the session doc.
    match /live_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid;
      allow update: if request.auth != null
                    && (
                      // Host can update anything
                      resource.data.hostId == request.auth.uid
                      ||
                      // Students can only increment participantCount
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['participantCount'])
                    );
      allow delete: if request.auth != null
                    && resource.data.hostId == request.auth.uid;

      // ── Participants subcollection ──────────────────────────────────────
      match /participants/{userId} {
        allow read: if request.auth != null;
        // Students can create/update their own participant doc
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
                      && (
                        request.auth.uid == userId
                        ||
                        // Host can update (kick, score update)
                        get(/databases/$(database)/documents/live_sessions/$(sessionId)).data.hostId
                          == request.auth.uid
                      );
        // Only host can delete (kick)
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/live_sessions/$(sessionId)).data.hostId
                        == request.auth.uid;
      }
    }

    // ── Live Answers ────────────────────────────────────────────────────────
    // Students submit their own answers. Everyone can read (for leaderboard).
    match /live_answers/{answerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.participantId == request.auth.uid;
      // No updates or deletes — answers are immutable
      allow update, delete: if false;
    }

    // ── Upload Tracker (subcollection under users) ──────────────────────────
    match /users/{userId}/uploadTracker/{doc} {
      // Only the user can read/write their own upload tracker
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Feedback & Support ──────────────────────────────────────────────────
    // Users can submit feedback and read their own submissions
    // Admins/teachers can read all feedback
    match /feedbacks/{feedbackId} {
      allow read: if request.auth != null
                  && (
                    // User can read their own feedback
                    resource.data.userId == request.auth.uid
                    ||
                    // Teachers can read all feedback (admin access)
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
                  );
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      // Only teachers (admins) can update feedback (status, response)
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      allow delete: if false; // Feedback cannot be deleted
    }

    // ── Feedback Daily Trackers ─────────────────────────────────────────────
    // Track daily submission limits (3 per day per user)
    match /feedback_daily_trackers/{trackerId} {
      allow read: if request.auth != null
                  && trackerId.matches('^' + request.auth.uid + '_.*');
      allow create, update: if request.auth != null
                            && trackerId.matches('^' + request.auth.uid + '_.*')
                            && request.resource.data.userId == request.auth.uid;
      allow delete: if false; // Trackers should not be deleted
    }

    // ── Payments ────────────────────────────────────────────────────────────
    // Teachers can create, read, update payment records for their students.
    // Students can only read their own payment record.
    match /payments/{paymentId} {
      // Student reads their own; teacher reads all
      allow read: if request.auth != null
                  && (
                    resource.data.studentId == request.auth.uid
                    ||
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
                  );
      // Only teachers can create payment records
      allow create: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      // Only teachers can update payment records (mark paid/due/overdue)
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      // Only teachers can delete payment records
      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
  }
}
