# Cloudinary Configuration (for unsigned uploads)
# Note: Cloud name and upload preset are safe to expose for unsigned uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# WARNING: Do NOT add API_KEY or API_SECRET here!
# These should only be in backend/Firebase Functions if using signed uploads

# Web3Forms Configuration
# Get your free access key from https://web3forms.com
# Used to send feedback form submissions to your email inbox
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here
